# _version_gt
#
# Compara dos versiones semver y determina si la primera es mayor que la segunda.
#
# Args:
#   $1 - Versión A (ej: "1.2.0")
#   $2 - Versión B (ej: "1.1.3")
#
# Returns:
#   0 si A > B, 1 en caso contrario.
_version_gt() {
  local a="$1" b="$2"
  # Divide cada versión en major.minor.patch y compara numéricamente
  local IFS='.'
  read -r a1 a2 a3 <<< "$a"
  read -r b1 b2 b3 <<< "$b"
  a1="${a1:-0}"; a2="${a2:-0}"; a3="${a3:-0}"
  b1="${b1:-0}"; b2="${b2:-0}"; b3="${b3:-0}"
  (( a1 > b1 )) && return 0
  (( a1 == b1 && a2 > b2 )) && return 0
  (( a1 == b1 && a2 == b2 && a3 > b3 )) && return 0
  return 1
}

# cmd_update
#
# Descarga la última versión del script desde GitHub, la valida y reemplaza
# el binario instalado. Requiere permiso de escritura sobre el binario.
#
# Args:
#   $@ - Opciones de línea de comandos.
cmd_update() {
  local force=0 timeout=15

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      -f|--force)   force=1; shift ;;
      -t|--timeout) timeout="${2:-15}"; shift 2 || { err "Falta valor para --timeout"; exit 2; } ;;
      -h|--help)    usage_update; exit 0 ;;
      *) err "Opción no reconocida: $1"; usage_update; exit 2 ;;
    esac
  done

  local raw_url="https://raw.githubusercontent.com/ONieto/pvesearchin/main/pvesearchin"
  local ver_url="https://raw.githubusercontent.com/ONieto/pvesearchin/main/version.txt"

  # Localizar el binario instalado
  local self
  self="$(command -v pvesearchin 2>/dev/null || true)"
  if [[ -z "$self" ]]; then
    self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  fi

  banner
  echo
  printf " ${BOLD}🔄 Actualización de pvesearchin${RST}\n"
  printf " ${DIM}🗓  %s${RST}\n" "$(date +'%F %T')"
  hr

  info "Versión instalada:  ${BOLD}v${VERSION}${RST}"
  info "Binario:            ${DIM}${self}${RST}"
  echo

  # Verificar permiso de escritura antes de descargar nada
  if [[ ! -w "$self" ]]; then
    err "Sin permiso de escritura sobre: ${BOLD}${self}${RST}"
    info "Ejecuta con sudo:   ${BOLD}sudo pvesearchin update${RST}"
    exit 1
  fi

  # Verificar disponibilidad de curl o wget
  local downloader=""
  if command -v curl >/dev/null 2>&1; then
    downloader="curl"
  elif command -v wget >/dev/null 2>&1; then
    downloader="wget"
  else
    err "No se encontró curl ni wget. Instala uno e intenta de nuevo."
    exit 1
  fi

  # Función interna de descarga
  _fetch() {
    local url="$1" dest="$2"
    if [[ "$downloader" == "curl" ]]; then
      curl -fsSL --max-time "$timeout" "$url" -o "$dest" 2>/dev/null
    else
      wget -qO "$dest" --timeout="$timeout" "$url" 2>/dev/null
    fi
  }

  # --- Paso 1: obtener versión remota ---
  info "Consultando versión disponible en GitHub..."
  local tmp_ver; tmp_ver="$(mktemp)"
  if ! _fetch "$ver_url" "$tmp_ver" || [[ ! -s "$tmp_ver" ]]; then
    rm -f "$tmp_ver"
    err "No se pudo obtener la versión remota. Verifica tu conexión."
    exit 1
  fi
  local remote_version
  remote_version="$(tr -d '[:space:]' < "$tmp_ver")"
  rm -f "$tmp_ver"

  info "Versión disponible:  ${BOLD}v${remote_version}${RST}"
  echo

  # --- Paso 2: comparar versiones ---
  if ! _version_gt "$remote_version" "$VERSION" && (( ! force )); then
    ok "Ya tienes la versión más reciente ${BOLD}(v${VERSION})${RST}."
    info "Usa ${BOLD}--force${RST} para reinstalar igualmente."
    echo
    exit 0
  fi

  if (( force )) && ! _version_gt "$remote_version" "$VERSION"; then
    warn "Reinstalando v${remote_version} (--force activado)."
  else
    info "Nueva versión disponible: ${BOLD}v${VERSION}${RST} → ${GRN}v${remote_version}${RST}"
  fi

  # --- Paso 3: descargar a archivo temporal ---
  info "Descargando v${remote_version}..."
  local tmp_script; tmp_script="$(mktemp)"
  if ! _fetch "$raw_url" "$tmp_script" || [[ ! -s "$tmp_script" ]]; then
    rm -f "$tmp_script"
    err "Error al descargar la actualización."
    exit 1
  fi

  # --- Paso 4: validar que sea un script bash válido ---
  if ! bash -n "$tmp_script" 2>/dev/null; then
    rm -f "$tmp_script"
    err "El archivo descargado no pasó la validación de sintaxis bash. Abortando."
    info "El binario instalado NO fue modificado."
    exit 1
  fi

  # --- Paso 5: reemplazar el binario ---
  chmod +x "$tmp_script"
  mv "$tmp_script" "$self"

  echo
  hr
  ok "Actualizado: v${VERSION} → ${GRN}v${remote_version}${RST}"
  ok "Instalado en: ${BOLD}${self}${RST}"
  echo
}

# ======================= HELPER INTERNO ==========================
_print_failed_summary() {
  if (( ${#FAILED[@]} > 0 )); then
    warn "Servidores sin respuesta (${#FAILED[@]}):"
    for f in "${FAILED[@]}"; do printf "   ${DIM}✖ %s${RST}\n" "$f"; done
    echo
  fi
}

# ======================= MAIN ==========================
# main
#
# Punto de entrada principal. Parsea el primer argumento como subcomando
# y delega al handler correspondiente. Cualquier argumento no reconocido
# como subcomando se trata como término de búsqueda directo.
#
# Args:
#   $@ - Argumentos de línea de comandos originales del script.
main() {
  [[ $# -eq 0 ]] && { banner; echo; usage_main; exit 0; }

  local CMD="${1}"; shift

  case "$CMD" in
  search)                   cmd_search       "$@" ;;
  nodes|ls-all)             cmd_nodes        "$@" ;;
  status)                   cmd_status       "$@" ;;
  orphans)                  cmd_orphans      "$@" ;;
  backups|backup)           cmd_backups      "$@" ;;
  check-access|ssh-check)   cmd_check_access "$@" ;;
  update)                   cmd_update       "$@" ;;
  add)                      cmd_add          "$@" ;;
  remove|rm|delete)         cmd_remove       "$@" ;;
  edit)                     cmd_edit         "$@" ;;
  list|ls)                  cmd_list         "$@" ;;
  export)                   cmd_export       "$@" ;;
  import)                   cmd_import       "$@" ;;
  version|-V|--version)     printf "pvesearchin v%s\n" "$VERSION"; exit 0 ;;
  -h|--help)                banner; echo; usage_main; exit 0 ;;
  help)
    if [[ $# -gt 0 ]]; then
      case "${1}" in
        search)                 banner; echo; usage_search;       exit 0 ;;
        nodes|ls-all)           banner; echo; usage_nodes;        exit 0 ;;
        status)                 banner; echo; usage_status;       exit 0 ;;
        orphans)                banner; echo; usage_orphans;      exit 0 ;;
        backups|backup)         banner; echo; usage_backups;      exit 0 ;;
        check-access|ssh-check) banner; echo; usage_check_access; exit 0 ;;
        update)                 banner; echo; usage_update;       exit 0 ;;
        add)                    banner; echo; usage_add;          exit 0 ;;
        remove|rm|delete)       banner; echo; usage_remove;        exit 0 ;;
        edit)                   banner; echo; usage_edit;          exit 0 ;;
        list|ls)                banner; echo; usage_list;          exit 0 ;;
        export)                 banner; echo; usage_export;        exit 0 ;;
        import)                 banner; echo; usage_import;       exit 0 ;;
        version)
          printf "\n${BOLD}Uso:${RST}\n  pvesearchin version\n\n"
          printf "Muestra la versión instalada.\n\n"; exit 0 ;;
        *) err "Comando no reconocido: ${1}"; echo; usage_main; exit 2 ;;
      esac
    fi
    banner; echo; usage_main; exit 0
    ;;
  # Cualquier otra cosa se interpreta como búsqueda directa
  *)  cmd_search "$CMD" "$@" ;;
  esac
}

main "$@"
