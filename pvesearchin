# ======================= CMD: status ==========================
cmd_status() {
  local host_filter="" timeout=10 verbose=0

  if [[ $# -gt 0 && "${1}" != -* ]]; then
    host_filter="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      -t|--timeout) timeout="${2:-10}"; shift 2 || { err "Falta valor para --timeout"; exit 2; } ;;
      -v|--verbose) verbose=1; shift ;;
      -h|--help)    usage_status; exit 0 ;;
      *) err "Opción no reconocida: $1"; usage_status; exit 2 ;;
    esac
  done

  ensure_config

  banner
  echo
  printf " ${BOLD}📊 Resumen del clúster Proxmox${RST}"
  [[ -n "$host_filter" ]] && printf "  ${DIM}nodo=%s${RST}" "$host_filter"
  echo
  printf " ${DIM}🗓  %s${RST}\n" "$(date +'%F %T')"
  hr

  local entries_blob; entries_blob="$(get_target_entries "$host_filter")"

  if [[ -z "$entries_blob" ]]; then
    warn "No hay servidores configurados."
    info "Agrega uno con: ${BOLD}pvesearchin add <hostname>${RST}"
    echo; exit 0
  fi

  local total; total="$(echo "$entries_blob" | grep -c . || true)"
  info "Consultando ${BOLD}${total}${RST} servidor(es)..."
  echo

  local -a SSH_OPTS=("${SSH_BASE_OPTS[@]}" -o ConnectTimeout="$timeout")
  local -a FAILED_ST=()

  # Acumular filas de status
  declare -a ST_HOST=()
  declare -a ST_NODO=()
  declare -a ST_CORES=()
  declare -a ST_LOAD=()
  declare -a ST_RAM_USED=()
  declare -a ST_RAM_TOTAL=()
  declare -a ST_DISK=()
  declare -a ST_VER=()
  declare -a ST_UPTIME=()
  declare -a ST_VMS=()
  declare -a ST_CTS=()

  local idx=0
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    idx=$(( idx + 1 ))

    IFS=':' read -r srv_h srv_p srv_u <<< "${entry}::"
    srv_p="${srv_p:-$DEFAULT_PORT}"; srv_u="${srv_u:-$DEFAULT_USER}"

    if (( verbose )); then
      printf "   ${DIM}[%d/%d]${RST} Conectando a ${BOLD}%s${RST}:%s...\n" \
        "$idx" "$total" "$srv_h" "$srv_p"
    else
      printf "   ${DIM}[%d/%d] %s${RST}\n" "$idx" "$total" "$srv_h"
    fi

    if ! ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" true 2>/dev/null; then
      warn "Sin respuesta: ${BOLD}${srv_h}${RST}"
      FAILED_ST+=("$srv_h")
      continue
    fi

    local raw=""
    raw="$(ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" bash -s 2>/dev/null <<'REMOTESTATUS'
#!/bin/sh
NODE="$(hostname -s 2>/dev/null || hostname)"
CORES="$(nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null || echo '?')"
LOAD="$(awk '{print $1}' /proc/loadavg 2>/dev/null || echo '?')"

MEM_TOTAL_KB="$(awk '/^MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)"
MEM_AVAIL_KB="$(awk '/^MemAvailable/{print $2}' /proc/meminfo 2>/dev/null || echo 0)"
MEM_USED_MB=$(( (MEM_TOTAL_KB - MEM_AVAIL_KB) / 1024 ))
MEM_TOTAL_MB=$(( MEM_TOTAL_KB / 1024 ))

DISK="$(df -h / 2>/dev/null | awk 'NR==2{print $3"/"$2" ("$5")"}'  || echo '?')"
PVE_VER="$(pveversion 2>/dev/null | awk '{print $2}' | head -1 || echo 'N/D')"
UPTIME_RAW="$(cat /proc/uptime 2>/dev/null | awk '{print $1}' || echo 0)"
UPTIME_DAYS=$(( ${UPTIME_RAW%.*} / 86400 ))
UPTIME_HRS=$(( (${UPTIME_RAW%.*} % 86400) / 3600 ))
UPTIME="${UPTIME_DAYS}d ${UPTIME_HRS}h"

VMS="$(qm list 2>/dev/null | awk 'NR>1' | wc -l || echo 0)"
CTS="$(pct list 2>/dev/null | awk 'NR>1' | wc -l || echo 0)"

printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
  "$NODE" "$CORES" "$LOAD" "$MEM_USED_MB" "$MEM_TOTAL_MB" "$DISK" "$PVE_VER" "$UPTIME" "$VMS" "$CTS"
REMOTESTATUS
    )" || true

    if [[ -n "$raw" ]]; then
      IFS='|' read -r nodo cores load ram_used ram_total disk ver uptime vms cts <<< "${raw}"
      ST_HOST+=("$srv_h")
      ST_NODO+=("$nodo")
      ST_CORES+=("$cores")
      ST_LOAD+=("$load")
      ST_RAM_USED+=("${ram_used}M")
      ST_RAM_TOTAL+=("${ram_total}M")
      ST_DISK+=("$disk")
      ST_VER+=("$ver")
      ST_UPTIME+=("$uptime")
      ST_VMS+=("$vms")
      ST_CTS+=("$cts")
    fi
  done <<< "$entries_blob"

  echo
  hr

  local rows=${#ST_HOST[@]}
  if (( rows == 0 )); then
    warn "No se pudo obtener información de ningún servidor."
  else
    printf "%b\n" " ${BOLD}${GRN}✔ Datos de ${rows} nodo(s)${RST}"
    echo

    # Anchos dinámicos de columna (W_VM y W_CT son fijos en 3 — "VMs"/"CTs")
    local W_H=8 W_N=5 W_C=6 W_L=6 W_RAM=9 W_D=12 W_V=7 W_U=8
    for i in "${!ST_HOST[@]}"; do
      [[ ${#ST_HOST[$i]}     -gt $W_H  ]] && W_H=${#ST_HOST[$i]}
      [[ ${#ST_NODO[$i]}     -gt $W_N  ]] && W_N=${#ST_NODO[$i]}
      [[ ${#ST_LOAD[$i]}     -gt $W_L  ]] && W_L=${#ST_LOAD[$i]}
      [[ ${#ST_RAM_USED[$i]} -gt $W_RAM ]] && W_RAM=${#ST_RAM_USED[$i]}
      [[ ${#ST_DISK[$i]}     -gt $W_D  ]] && W_D=${#ST_DISK[$i]}
      [[ ${#ST_VER[$i]}      -gt $W_V  ]] && W_V=${#ST_VER[$i]}
      [[ ${#ST_UPTIME[$i]}   -gt $W_U  ]] && W_U=${#ST_UPTIME[$i]}
    done

    local sep_h;  sep_h="$(printf  '─%.0s' $(seq 1 $W_H))"
    local sep_n;  sep_n="$(printf  '─%.0s' $(seq 1 $W_N))"
    local sep_c;  sep_c="$(printf  '─%.0s' $(seq 1 $W_C))"
    local sep_l;  sep_l="$(printf  '─%.0s' $(seq 1 $W_L))"
    local sep_ram; sep_ram="$(printf '─%.0s' $(seq 1 $W_RAM))"
    local sep_d;  sep_d="$(printf  '─%.0s' $(seq 1 $W_D))"
    local sep_v;  sep_v="$(printf  '─%.0s' $(seq 1 $W_V))"
    local sep_u;  sep_u="$(printf  '─%.0s' $(seq 1 $W_U))"

    printf "   %b%-${W_H}s  %-${W_N}s  %-${W_C}s  %-${W_L}s  %-${W_RAM}s  %-${W_D}s  %-${W_V}s  %-${W_U}s  %s  %s%b\n" \
      "${BOLD}" "SERVIDOR" "NODO" "CORES" "CARGA" "RAM USADA" "DISCO /" "PVE" "UPTIME" "VMs" "CTs" "${RST}"
    printf "   ${DIM}%s  %s  %s  %s  %s  %s  %s  %s  %s  %s${RST}\n" \
      "$sep_h" "$sep_n" "$sep_c" "$sep_l" "$sep_ram" "$sep_d" "$sep_v" "$sep_u" "───" "───"

    for i in "${!ST_HOST[@]}"; do
      # Color de carga
      local l_color="${GRN}"
      local load_int="${ST_LOAD[$i]%.*}"
      local cores_int="${ST_CORES[$i]}"
      if [[ "$load_int" =~ ^[0-9]+$ && "$cores_int" =~ ^[0-9]+$ ]]; then
        (( load_int >= cores_int )) && l_color="${RED}"
        (( load_int >= cores_int / 2 )) && (( load_int < cores_int )) && l_color="${YLW}"
      fi

      printf "   ${CYN}%-${W_H}s${RST}  %-${W_N}s  ${DIM}%-${W_C}s${RST}  %b%-${W_L}s${RST}  %-${W_RAM}s  %-${W_D}s  ${DIM}%-${W_V}s${RST}  %-${W_U}s  ${GRN}%-3s${RST}  ${BLU}%-3s${RST}\n" \
        "${ST_HOST[$i]}" "${ST_NODO[$i]}" "${ST_CORES[$i]}" \
        "${l_color}" "${ST_LOAD[$i]}" \
        "${ST_RAM_USED[$i]}/${ST_RAM_TOTAL[$i]}" \
        "${ST_DISK[$i]}" "${ST_VER[$i]}" "${ST_UPTIME[$i]}" \
        "${ST_VMS[$i]}" "${ST_CTS[$i]}"
    done
  fi

  echo
  hr
  if (( ${#FAILED_ST[@]} > 0 )); then
    warn "Servidores sin respuesta (${#FAILED_ST[@]}):"
    for f in "${FAILED_ST[@]}"; do printf "   ${DIM}✖ %s${RST}\n" "$f"; done
    echo
  fi
  ok "FIN  ${DIM}(consultados: ${total} | errores: ${#FAILED_ST[@]} | respondieron: ${rows})${RST}"
}

# ======================= CMD: orphans ==========================
cmd_orphans() {
  local host_filter="" timeout=10 verbose=0 days=30

  if [[ $# -gt 0 && "${1}" != -* ]]; then
    host_filter="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      -d|--days)    days="${2:-30}";    shift 2 || { err "Falta valor para --days";    exit 2; } ;;
      -t|--timeout) timeout="${2:-10}"; shift 2 || { err "Falta valor para --timeout"; exit 2; } ;;
      -v|--verbose) verbose=1; shift ;;
      -h|--help)    usage_orphans; exit 0 ;;
      *) err "Opción no reconocida: $1"; usage_orphans; exit 2 ;;
    esac
  done

  [[ "$days" =~ ^[0-9]+$ ]] || { err "--days debe ser un número entero positivo."; exit 2; }

  ensure_config
  reset_results
  FAILED=()

  banner
  echo
  printf " ${BOLD}👻 VMs/CTs huérfanas — apagadas sin cambios ≥ %s días${RST}" "$days"
  [[ -n "$host_filter" ]] && printf "  ${DIM}nodo=%s${RST}" "$host_filter"
  echo
  printf " ${DIM}🗓  %s${RST}\n" "$(date +'%F %T')"
  hr

  local entries_blob; entries_blob="$(get_target_entries "$host_filter")"

  if [[ -z "$entries_blob" ]]; then
    warn "No hay servidores configurados."
    echo; exit 0
  fi

  local total; total="$(echo "$entries_blob" | grep -c . || true)"
  info "Consultando ${BOLD}${total}${RST} servidor(es)  ${DIM}(umbral: ${days} días)${RST}..."
  echo

  # Script remoto: recibe $1=days
  REMOTE_SCRIPT='#!/bin/sh
DAYS="$1"
CUTOFF=$(( DAYS * 86400 ))
NOW="$(date +%s)"

check_stopped() {
  local vmid="$1" name="$2" type="$3" conf="$4"
  local mtime age age_days
  if [ -f "$conf" ]; then
    mtime="$(stat -c %Y "$conf" 2>/dev/null || echo 0)"
    age=$(( NOW - mtime ))
    if [ "$age" -ge "$CUTOFF" ]; then
      age_days=$(( age / 86400 ))
      printf "%s|%s|stopped|%s|%sd\n" "$vmid" "$name" "$type" "$age_days"
    fi
  fi
}

if command -v qm >/dev/null 2>&1; then
  qm list 2>/dev/null | awk "NR>1 && \$3==\"stopped\"" | while read -r vmid name status rest; do
    check_stopped "$vmid" "$name" "VM" "/etc/pve/qemu-server/${vmid}.conf"
  done
fi
if command -v pct >/dev/null 2>&1; then
  pct list 2>/dev/null | awk "NR>1 && \$2==\"stopped\"" | while read -r vmid status name rest; do
    check_stopped "$vmid" "$name" "CT" "/etc/pve/lxc/${vmid}.conf"
  done
fi'

  run_remote_collect "$entries_blob" "$timeout" "$verbose" "$days"

  echo
  hr

  local found=${#G_VMID[@]}
  if (( found == 0 )); then
    ok "No se detectaron VMs/CTs huérfanas con umbral de ${BOLD}${days}${RST} días."
  else
    printf "%b\n" " ${BOLD}${YLW}⚠ ${found} VM(s)/CT(s) candidata(s) a huérfana${RST}  ${DIM}(sin cambios ≥ ${days} días)${RST}"
    info "La columna ${BOLD}SIN CAMBIOS${RST} refleja días desde la última modificación de configuración."
    echo
    render_vmct_table "SIN CAMBIOS"
  fi

  echo
  hr
  _print_failed_summary
  ok "FIN  ${DIM}(servidores: ${total} | errores: ${#FAILED[@]} | huérfanas detectadas: ${found})${RST}"
}

# ======================= CMD: check-access ==========================
cmd_check_access() {
  local timeout=10

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      -t|--timeout) timeout="${2:-10}"; shift 2 || { err "Falta valor para --timeout"; exit 2; } ;;
      -h|--help)    usage_check_access; exit 0 ;;
      *) err "Opción no reconocida: $1"; usage_check_access; exit 2 ;;
    esac
  done

  ensure_config

  banner
  echo
  printf " ${BOLD}🔑 Verificación de acceso SSH${RST}\n"
  printf " ${DIM}🗓  %s${RST}\n" "$(date +'%F %T')"
  hr

  local entries=()
  while IFS= read -r line; do
    entries+=("$line")
  done < <(read_servers)

  if (( ${#entries[@]} == 0 )); then
    warn "No hay servidores configurados."
    info "Agrega uno con: ${BOLD}pvesearchin add <hostname>${RST}"
    echo; exit 0
  fi

  local -a SSH_OPTS=("${SSH_BASE_OPTS[@]}" -o ConnectTimeout="$timeout")

  local -a CA_HOST=() CA_PORT=() CA_USER=() CA_STATUS=() CA_VER=() CA_KEY=()
  local ok_count=0 fail_count=0

  local idx=0 total=${#entries[@]}
  info "Verificando ${BOLD}${total}${RST} servidor(es)..."
  echo

  for entry in "${entries[@]}"; do
    idx=$(( idx + 1 ))
    IFS=':' read -r srv_h srv_p srv_u <<< "${entry}::"
    srv_p="${srv_p:-$DEFAULT_PORT}"; srv_u="${srv_u:-$DEFAULT_USER}"

    printf "   ${DIM}[%d/%d]${RST} %s:%s..." "$idx" "$total" "$srv_h" "$srv_p"

    local pve_ver="N/D" status_str="" key_info=""

    if ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" true 2>/dev/null; then
      pve_ver="$(ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" \
        "pveversion 2>/dev/null | awk '{print \$2}' | head -1 || echo 'N/D'" 2>/dev/null || echo 'N/D')"
      # Detectar qué llave fue usada (ssh -v filtra la llave aceptada)
      key_info="$(ssh "${SSH_OPTS[@]}" -v -p "$srv_p" "${srv_u}@${srv_h}" true 2>&1 | \
        grep -o 'Offering public key: .*' | head -1 | sed 's/Offering public key: //' || echo '')"
      [[ -z "$key_info" ]] && key_info="auto"
      status_str="OK"
      ok_count=$(( ok_count + 1 ))
      printf " ${GRN}✔${RST}\n"
    else
      status_str="FALLO"
      fail_count=$(( fail_count + 1 ))
      key_info="—"
      printf " ${RED}✖${RST}\n"
    fi

    CA_HOST+=("$srv_h"); CA_PORT+=("$srv_p"); CA_USER+=("$srv_u")
    CA_STATUS+=("$status_str"); CA_VER+=("$pve_ver"); CA_KEY+=("$key_info")
  done

  echo
  hr
  printf "%b\n" " ${BOLD}📋 Resultado${RST}"
  echo

  # Anchos dinámicos
  local W_H=8 W_P=6 W_U=7 W_ST=6 W_V=7 W_K=4
  for i in "${!CA_HOST[@]}"; do
    [[ ${#CA_HOST[$i]}   -gt $W_H  ]] && W_H=${#CA_HOST[$i]}
    [[ ${#CA_PORT[$i]}   -gt $W_P  ]] && W_P=${#CA_PORT[$i]}
    [[ ${#CA_USER[$i]}   -gt $W_U  ]] && W_U=${#CA_USER[$i]}
    [[ ${#CA_STATUS[$i]} -gt $W_ST ]] && W_ST=${#CA_STATUS[$i]}
    [[ ${#CA_VER[$i]}    -gt $W_V  ]] && W_V=${#CA_VER[$i]}
    [[ ${#CA_KEY[$i]}    -gt $W_K  ]] && W_K=${#CA_KEY[$i]}
  done

  local sep_h;  sep_h="$(printf  '─%.0s' $(seq 1 $W_H))"
  local sep_p;  sep_p="$(printf  '─%.0s' $(seq 1 $W_P))"
  local sep_u;  sep_u="$(printf  '─%.0s' $(seq 1 $W_U))"
  local sep_st; sep_st="$(printf '─%.0s' $(seq 1 $W_ST))"
  local sep_v;  sep_v="$(printf  '─%.0s' $(seq 1 $W_V))"
  local sep_k;  sep_k="$(printf  '─%.0s' $(seq 1 $W_K))"

  printf "   %b%-${W_H}s  %-${W_P}s  %-${W_U}s  %-${W_ST}s  %-${W_V}s  %-${W_K}s%b\n" \
    "${BOLD}" "SERVIDOR" "PUERTO" "USUARIO" "ESTADO" "PVE" "LLAVE" "${RST}"
  printf "   ${DIM}%s  %s  %s  %s  %s  %s${RST}\n" \
    "$sep_h" "$sep_p" "$sep_u" "$sep_st" "$sep_v" "$sep_k"

  for i in "${!CA_HOST[@]}"; do
    local s_color=""
    [[ "${CA_STATUS[$i]}" == "OK"    ]] && s_color="${GRN}"
    [[ "${CA_STATUS[$i]}" == "FALLO" ]] && s_color="${RED}"

    printf "   ${CYN}%-${W_H}s${RST}  %-${W_P}s  ${DIM}%-${W_U}s${RST}  %b%-${W_ST}s${RST}  ${DIM}%-${W_V}s${RST}  %-${W_K}s\n" \
      "${CA_HOST[$i]}" "${CA_PORT[$i]}" "${CA_USER[$i]}" \
      "${s_color}" "${CA_STATUS[$i]}" "${CA_VER[$i]}" "${CA_KEY[$i]}"
  done

  echo
  hr
  ok "FIN  ${DIM}(total: ${total} | ${GRN}OK: ${ok_count}${RST} | ${RED}fallos: ${fail_count}${RST})${RST}"
}

# ======================= CMD: backups ==========================
cmd_backups() {
  local host_filter="" timeout=10 verbose=0 days=30
  local filter_backed=0 filter_unbacked=0

  if [[ $# -gt 0 && "${1}" != -* ]]; then
    host_filter="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "${1:-}" in
      --backed)     filter_backed=1; shift ;;
      --unbacked)   filter_unbacked=1; shift ;;
      -d|--days)    days="${2:-30}"; shift 2 || { err "Falta valor para --days"; exit 2; } ;;
      -t|--timeout) timeout="${2:-10}"; shift 2 || { err "Falta valor para --timeout"; exit 2; } ;;
      -v|--verbose) verbose=1; shift ;;
      -h|--help)    usage_backups; exit 0 ;;
      *) err "Opción no reconocida: $1"; usage_backups; exit 2 ;;
    esac
  done

  [[ "$days" =~ ^[0-9]+$ ]] || { err "--days debe ser un número entero positivo."; exit 2; }

  if (( filter_backed && filter_unbacked )); then
    err "--backed y --unbacked son mutuamente excluyentes."; exit 2
  fi

  ensure_config

  banner
  echo
  printf " ${BOLD}💾 Resumen de respaldos${RST}"
  [[ -n "$host_filter" ]]  && printf "  ${DIM}nodo=%s${RST}"           "$host_filter"
  (( filter_backed   ))    && printf "  ${DIM}filtro=con respaldo${RST}"
  (( filter_unbacked ))    && printf "  ${DIM}filtro=sin respaldo${RST}"
  echo
  printf " ${DIM}🗓  %s${RST}\n" "$(date +'%F %T')"
  hr

  local entries_blob; entries_blob="$(get_target_entries "$host_filter")"

  if [[ -z "$entries_blob" ]]; then
    warn "No hay servidores configurados."
    info "Agrega uno con: ${BOLD}pvesearchin add <hostname>${RST}"
    echo; exit 0
  fi

  local total; total="$(echo "$entries_blob" | grep -c . || true)"
  info "Consultando ${BOLD}${total}${RST} servidor(es)  ${DIM}(umbral reciente: ${days} días)${RST}..."
  echo

  local -a SSH_OPTS=("${SSH_BASE_OPTS[@]}" -o ConnectTimeout="$timeout")
  local -a FAILED_BK=()

  declare -a BK_SERVER=()
  declare -a BK_VMID=()
  declare -a BK_NAME=()
  declare -a BK_TYPE=()
  declare -a BK_DATE=()
  declare -a BK_AGE=()

  local idx=0
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    idx=$(( idx + 1 ))

    IFS=':' read -r srv_h srv_p srv_u <<< "${entry}::"
    srv_p="${srv_p:-$DEFAULT_PORT}"; srv_u="${srv_u:-$DEFAULT_USER}"

    if (( verbose )); then
      printf "   ${DIM}[%d/%d]${RST} Conectando a ${BOLD}%s${RST}:%s  (usuario: %s)...\n" \
        "$idx" "$total" "$srv_h" "$srv_p" "$srv_u"
    else
      printf "   ${DIM}[%d/%d] %s${RST}\n" "$idx" "$total" "$srv_h"
    fi

    if ! ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" true 2>/dev/null; then
      warn "Sin respuesta: ${BOLD}${srv_h}${RST}:${srv_p}"
      FAILED_BK+=("$srv_h")
      continue
    fi

    local raw=""
    raw="$(ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" bash -s 2>/dev/null <<'REMOTEBK'
#!/bin/sh
# Recolecta el backup más reciente por VMID desde todos los storages
tmpbk=$(mktemp)

for st in $(pvesm status --content backup 2>/dev/null | awk 'NR>1 {print $1}'); do
  pvesm list "$st" --content backup 2>/dev/null | awk 'NR>1 {print $1}' | while IFS= read -r volid; do
    fname="${volid##*/}"
    vmid=$(printf '%s' "$fname" | sed -n 's/vzdump-[^-]*-\([0-9]\{1,\}\)-.*/\1/p')
    [ -z "$vmid" ] && continue
    datepart=$(printf '%s' "$fname" | sed -n 's/vzdump-[^-]*-[0-9]*-\([0-9_]*-[0-9_]*\)\..*/\1/p')
    [ -z "$datepart" ] && continue
    yr=$(printf '%s' "$datepart" | cut -c1-4)
    mo=$(printf '%s' "$datepart" | cut -c6-7)
    dy=$(printf '%s' "$datepart" | cut -c9-10)
    hr=$(printf '%s' "$datepart" | cut -c12-13)
    mn=$(printf '%s' "$datepart" | cut -c15-16)
    epoch=$(date -d "${yr}-${mo}-${dy} ${hr}:${mn}:00" +%s 2>/dev/null || echo 0)
    [ "$epoch" -gt 0 ] && printf '%s %s\n' "$vmid" "$epoch"
  done
done | sort -k1,1 -k2,2rn | awk '!seen[$1]++ {print $1, $2}' > "$tmpbk"

NOW=$(date +%s)

process_guest() {
  local vmid="$1" name="$2" type="$3"
  local epoch age_days bkdate
  epoch=$(awk -v id="$vmid" '$1==id {print $2; exit}' "$tmpbk")
  if [ -n "$epoch" ] && [ "$epoch" -gt 0 ]; then
    age_days=$(( (NOW - epoch) / 86400 ))
    bkdate=$(date -d "@$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null || echo '?')
    printf '%s|%s|%s|%s|%s\n' "$vmid" "$name" "$type" "$bkdate" "$age_days"
  else
    printf '%s|%s|%s||\n' "$vmid" "$name" "$type"
  fi
}

if command -v qm >/dev/null 2>&1; then
  qm list 2>/dev/null | awk 'NR>1' | while read -r vmid name status rest; do
    process_guest "$vmid" "$name" "VM"
  done
fi
if command -v pct >/dev/null 2>&1; then
  pct list 2>/dev/null | awk 'NR>1' | while read -r vmid status name rest; do
    process_guest "$vmid" "$name" "CT"
  done
fi

rm -f "$tmpbk"
REMOTEBK
    )" || true

    if [[ -n "$raw" ]]; then
      while IFS='|' read -r vmid name type bkdate age; do
        [[ -z "$vmid" ]] && continue
        BK_SERVER+=("$srv_h")
        BK_VMID+=("$vmid")
        BK_NAME+=("$name")
        BK_TYPE+=("$type")
        BK_DATE+=("$bkdate")
        BK_AGE+=("$age")
      done <<< "$raw"
    fi
  done <<< "$entries_blob"

  echo
  hr

  # Aplicar filtros y calcular ESTADO
  local -a F_SERVER=() F_VMID=() F_NAME=() F_TYPE=() F_DATE=() F_AGE_STR=() F_ESTADO=()

  for i in "${!BK_VMID[@]}"; do
    local age="${BK_AGE[$i]}"
    local estado="" has_backup=0 age_str="—"

    if [[ -n "$age" && "$age" =~ ^[0-9]+$ ]]; then
      has_backup=1
      age_str="${age}d"
      if (( age <= days )); then
        estado="✔ reciente"
      else
        estado="⚠ antiguo"
      fi
    else
      estado="✖ sin respaldo"
    fi

    (( filter_backed   && ! has_backup )) && continue
    (( filter_unbacked && has_backup   )) && continue

    F_SERVER+=("${BK_SERVER[$i]}")
    F_VMID+=("${BK_VMID[$i]}")
    F_NAME+=("${BK_NAME[$i]}")
    F_TYPE+=("${BK_TYPE[$i]}")
    F_DATE+=("${BK_DATE[$i]:-—}")
    F_AGE_STR+=("$age_str")
    F_ESTADO+=("$estado")
  done

  local found=${#F_VMID[@]}

  if (( found == 0 )); then
    if (( filter_backed )); then
      warn "No se encontraron VMs/CTs con respaldo."
    elif (( filter_unbacked )); then
      warn "No se encontraron VMs/CTs sin respaldo."
    else
      warn "No se encontraron VMs/CTs."
    fi
  else
    if (( filter_unbacked )); then
      printf "%b\n" " ${BOLD}${YLW}⚠ ${found} VM(s)/CT(s) sin respaldo${RST}"
    else
      printf "%b\n" " ${BOLD}${GRN}✔ ${found} VM(s)/CT(s)${RST}"
    fi
    echo

    local W_SRV=8 W_VMID=4 W_NAME=6 W_TYPE=4 W_DATE=15 W_AGE=10 W_EST=6
    for i in "${!F_VMID[@]}"; do
      [[ ${#F_SERVER[$i]}  -gt $W_SRV  ]] && W_SRV=${#F_SERVER[$i]}
      [[ ${#F_VMID[$i]}    -gt $W_VMID ]] && W_VMID=${#F_VMID[$i]}
      [[ ${#F_NAME[$i]}    -gt $W_NAME ]] && W_NAME=${#F_NAME[$i]}
      [[ ${#F_TYPE[$i]}    -gt $W_TYPE ]] && W_TYPE=${#F_TYPE[$i]}
      [[ ${#F_DATE[$i]}    -gt $W_DATE ]] && W_DATE=${#F_DATE[$i]}
      [[ ${#F_AGE_STR[$i]} -gt $W_AGE  ]] && W_AGE=${#F_AGE_STR[$i]}
      [[ ${#F_ESTADO[$i]}  -gt $W_EST  ]] && W_EST=${#F_ESTADO[$i]}
    done

    local sep_srv;  sep_srv="$(printf  '─%.0s' $(seq 1 $W_SRV))"
    local sep_vmid; sep_vmid="$(printf '─%.0s' $(seq 1 $W_VMID))"
    local sep_name; sep_name="$(printf '─%.0s' $(seq 1 $W_NAME))"
    local sep_type; sep_type="$(printf '─%.0s' $(seq 1 $W_TYPE))"
    local sep_date; sep_date="$(printf '─%.0s' $(seq 1 $W_DATE))"
    local sep_age;  sep_age="$(printf  '─%.0s' $(seq 1 $W_AGE))"
    local sep_est;  sep_est="$(printf  '─%.0s' $(seq 1 $W_EST))"

    printf "   %b%-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %-${W_TYPE}s  %-${W_DATE}s  %-${W_AGE}s  %-${W_EST}s%b\n" \
      "${BOLD}" "SERVIDOR" "VMID" "NOMBRE" "TIPO" "ÚLTIMO RESPALDO" "ANTIGÜEDAD" "ESTADO" "${RST}"
    printf "   ${DIM}%s  %s  %s  %s  %s  %s  %s${RST}\n" \
      "$sep_srv" "$sep_vmid" "$sep_name" "$sep_type" "$sep_date" "$sep_age" "$sep_est"

    for i in "${!F_VMID[@]}"; do
      local t_color=""
      case "${F_TYPE[$i]}" in VM) t_color="${CYN}" ;; CT) t_color="${BLU}" ;; esac

      local e_color=""
      case "${F_ESTADO[$i]}" in
        "✔ reciente")     e_color="${GRN}" ;;
        "⚠ antiguo")      e_color="${YLW}" ;;
        "✖ sin respaldo") e_color="${RED}" ;;
      esac

      printf "   %-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %b%-${W_TYPE}s%b  %-${W_DATE}s  %-${W_AGE}s  %b%-${W_EST}s%b\n" \
        "${F_SERVER[$i]}" "${F_VMID[$i]}" "${F_NAME[$i]}" \
        "${t_color}" "${F_TYPE[$i]}" "${RST}" \
        "${F_DATE[$i]}" "${F_AGE_STR[$i]}" \
        "${e_color}" "${F_ESTADO[$i]}" "${RST}"
    done
  fi

  echo
  hr
  if (( ${#FAILED_BK[@]} > 0 )); then
    warn "Servidores sin respuesta (${#FAILED_BK[@]}):"
    for f in "${FAILED_BK[@]}"; do printf "   ${DIM}✖ %s${RST}\n" "$f"; done
    echo
  fi
  ok "FIN  ${DIM}(servidores: ${total} | errores: ${#FAILED_BK[@]} | VMs/CTs: ${found})${RST}"
}

