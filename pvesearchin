#!/usr/bin/env bash
#
# pvesearchin — Proxmox VM/CT Search
#
# Busca, lista e inspecciona VMs y CTs en múltiples nodos Proxmox VE.
# Gestiona el listado de servidores en ~/.config/pvesearchin/servers
# mediante llaves SSH sin contraseña.
#
# Uso:
#   pvesearchin <comando> [opciones]
#   pvesearchin <nombre|vmid>          # búsqueda directa
#
# Dependencias: bash 4+, ssh, qm, pct, pveversion (en cada nodo Proxmox)
# Repo:         https://github.com/ONieto/pvesearchin
# Estándar:     Google Shell Style Guide (https://google.github.io/styleguide/shellguide.html)

set -euo pipefail
IFS=$'\n\t'

# ======================= CONSTANTES GLOBALES ==========================
readonly VERSION="1.3.1"
readonly CONFIG_DIR="${HOME}/.config/pvesearchin"
readonly CONFIG_FILE="${CONFIG_DIR}/servers"
readonly DEFAULT_USER="root"
readonly DEFAULT_PORT="22"
readonly HR="────────────────────────────────────────────────────────────────────────"

# ======================= ESTILO ==========================
# supports_color
#
# Comprueba si el terminal activo soporta al menos 8 colores.
#
# Returns:
#   0 si hay soporte de color, 1 en caso contrario.
supports_color() {
  [[ -t 1 ]] || return 1
  command -v tput >/dev/null 2>&1 || return 1
  local ncolors; ncolors=$(tput colors 2>/dev/null || echo 0)
  (( ncolors >= 8 ))
}

if supports_color; then
  BOLD="$(printf '\033[1m')"; DIM="$(printf '\033[2m')"
  RED="$(printf '\033[31m')";  GRN="$(printf '\033[32m')"; YLW="$(printf '\033[33m')"
  BLU="$(printf '\033[34m')";  CYN="$(printf '\033[36m')"; MAG="$(printf '\033[35m')"
  RST="$(printf '\033[0m')"
else
  BOLD=""; DIM=""; RED=""; GRN=""; YLW=""; BLU=""; CYN=""; MAG=""; RST=""
fi

hr()   { printf "%b\n" "${DIM}${HR}${RST}"; }
ok()   { printf "%b\n" " ${GRN}✔${RST} $*"; }
info() { printf "%b\n" " ${BLU}ℹ${RST} $*"; }
warn() { printf "%b\n" " ${YLW}⚠${RST} $*"; }
err()  { printf "%b\n" " ${RED}✖${RST} $*" >&2; }

banner() {
  printf "%b" "${BOLD}"
  cat <<'ASCII'
 _ ____   _____  ___  __ _ _ __ ___| |__ (_)_ __
| '_ \ \ / / _ \/ __|/ _` | '__/ __| '_ \| | '_ \
| |_) \ V /  __/\__ \ (_| | | | (__| | | | | | | |
| .__/ \_/ \___||___/\__,_|_|  \___|_| |_|_|_| |_|
|_|
ASCII
  printf "%b" "${RST}"
  printf "%b\n" "${DIM}       Proxmox VM/CT Search — v${VERSION}${RST}"
}

# ======================= SSH BASE ==========================
SSH_BASE_OPTS=(
  -o StrictHostKeyChecking=no
  -o BatchMode=yes
  -o PasswordAuthentication=no
  -o LogLevel=ERROR
)

# ======================= CONFIG ==========================
# ensure_config
#
# Crea el directorio y archivo de configuración si no existen.
ensure_config() {
  mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG_FILE" ]] || touch "$CONFIG_FILE"
}

# read_servers
#
# Lee el archivo de configuración e imprime las entradas activas.
# Ignora comentarios (líneas con #) y líneas vacías.
#
# Outputs:
#   Líneas con formato hostname:puerto:usuario a stdout.
read_servers() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  grep -v '^\s*#' "$CONFIG_FILE" | grep -v '^\s*$' || true
}

# server_exists
#
# Comprueba si un hostname ya existe en la configuración.
#
# Args:
#   $1 - Hostname a buscar.
#
# Returns:
#   0 si existe, 1 si no existe.
server_exists() {
  local host="$1"
  read_servers | awk -F: '{print $1}' | grep -qx "$host" 2>/dev/null
}

# get_target_entries
#
# Devuelve entradas del config, opcionalmente filtradas por hostname.
# Si se pasa un hostname que no existe, termina con error.
#
# Args:
#   $1 - (opcional) Hostname a filtrar.
#
# Outputs:
#   Líneas hostname:puerto:usuario a stdout.
get_target_entries() {
  local host_filter="${1:-}"
  if [[ -n "$host_filter" ]]; then
    if ! server_exists "$host_filter"; then
      err "El servidor ${BOLD}${host_filter}${RST} no está en la lista."
      info "Servidores disponibles: ${BOLD}pvesearchin list${RST}"
      exit 1
    fi
    read_servers | grep "^${host_filter}:"
  else
    read_servers
  fi
}

# ======================= TABLA COMPARTIDA VM/CT ==========================
# Las funciones de exploración acumulan resultados en estos arrays
# globales y luego invocan render_vmct_table para presentarlos.
declare -a G_SERVER=()
declare -a G_VMID=()
declare -a G_NAME=()
declare -a G_TYPE=()
declare -a G_STATUS=()
declare -a G_EXTRA=()   # columna extra opcional (ej: días sin cambios en orphans)

# reset_results
#
# Vacía todos los arrays globales de resultados.
reset_results() {
  G_SERVER=(); G_VMID=(); G_NAME=(); G_TYPE=(); G_STATUS=(); G_EXTRA=()
}

# render_vmct_table
#
# Imprime la tabla de resultados acumulados en los arrays G_*.
# Los anchos de columna se calculan dinámicamente según el contenido.
#
# Args:
#   $1 - (opcional) Título de la columna extra (usa G_EXTRA[]).
#
# Outputs:
#   Tabla formateada con colores a stdout.
# render_vmct_table [nombre_col_extra]
render_vmct_table() {
  local extra_hdr="${1:-}"
  local found=${#G_VMID[@]}

  if (( found == 0 )); then
    return 1
  fi

  local W_SRV=8 W_VMID=4 W_NAME=6 W_TYPE=4 W_ST=6 W_EX=0
  [[ -n "$extra_hdr" ]] && W_EX=${#extra_hdr}

  for i in "${!G_VMID[@]}"; do
    [[ ${#G_SERVER[$i]} -gt $W_SRV  ]] && W_SRV=${#G_SERVER[$i]}
    [[ ${#G_VMID[$i]}   -gt $W_VMID ]] && W_VMID=${#G_VMID[$i]}
    [[ ${#G_NAME[$i]}   -gt $W_NAME ]] && W_NAME=${#G_NAME[$i]}
    [[ ${#G_TYPE[$i]}   -gt $W_TYPE ]] && W_TYPE=${#G_TYPE[$i]}
    [[ ${#G_STATUS[$i]} -gt $W_ST   ]] && W_ST=${#G_STATUS[$i]}
    if [[ -n "$extra_hdr" && ${#G_EXTRA[$i]:-0} -gt $W_EX ]]; then
      W_EX=${#G_EXTRA[$i]}
    fi
  done

  local sep_srv;  sep_srv="$(printf  '─%.0s' $(seq 1 $W_SRV))"
  local sep_vmid; sep_vmid="$(printf '─%.0s' $(seq 1 $W_VMID))"
  local sep_name; sep_name="$(printf '─%.0s' $(seq 1 $W_NAME))"
  local sep_type; sep_type="$(printf '─%.0s' $(seq 1 $W_TYPE))"
  local sep_st;   sep_st="$(printf   '─%.0s' $(seq 1 $W_ST))"

  if [[ -n "$extra_hdr" ]]; then
    local sep_ex; sep_ex="$(printf '─%.0s' $(seq 1 $W_EX))"
    printf "   %b%-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %-${W_TYPE}s  %-${W_ST}s  %-${W_EX}s%b\n" \
      "${BOLD}" "SERVIDOR" "VMID" "NOMBRE" "TIPO" "ESTADO" "$extra_hdr" "${RST}"
    printf "   ${DIM}%s  %s  %s  %s  %s  %s${RST}\n" \
      "$sep_srv" "$sep_vmid" "$sep_name" "$sep_type" "$sep_st" "$sep_ex"
  else
    printf "   %b%-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %-${W_TYPE}s  %-${W_ST}s%b\n" \
      "${BOLD}" "SERVIDOR" "VMID" "NOMBRE" "TIPO" "ESTADO" "${RST}"
    printf "   ${DIM}%s  %s  %s  %s  %s${RST}\n" \
      "$sep_srv" "$sep_vmid" "$sep_name" "$sep_type" "$sep_st"
  fi

  for i in "${!G_VMID[@]}"; do
    local t_color=""
    case "${G_TYPE[$i]}" in VM) t_color="${CYN}" ;; CT) t_color="${BLU}" ;; esac

    local s_color=""
    case "${G_STATUS[$i],,}" in
      running) s_color="${GRN}" ;;
      stopped) s_color="${YLW}" ;;
      *)       s_color="${DIM}" ;;
    esac

    if [[ -n "$extra_hdr" ]]; then
      printf "   %-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %b%-${W_TYPE}s%b  %b%-${W_ST}s%b  ${MAG}%-${W_EX}s${RST}\n" \
        "${G_SERVER[$i]}" "${G_VMID[$i]}" "${G_NAME[$i]}" \
        "${t_color}" "${G_TYPE[$i]}"   "${RST}" \
        "${s_color}" "${G_STATUS[$i]}" "${RST}" \
        "${G_EXTRA[$i]:-}"
    else
      printf "   %-${W_SRV}s  %-${W_VMID}s  %-${W_NAME}s  %b%-${W_TYPE}s%b  %b%-${W_ST}s%b\n" \
        "${G_SERVER[$i]}" "${G_VMID[$i]}" "${G_NAME[$i]}" \
        "${t_color}" "${G_TYPE[$i]}"   "${RST}" \
        "${s_color}" "${G_STATUS[$i]}" "${RST}"
    fi
  done
}

# run_remote_collect
#
# Itera sobre un bloque de entradas de servidores, ejecuta el script
# almacenado en la variable global REMOTE_SCRIPT en cada nodo vía SSH,
# y acumula los resultados en los arrays G_*.
#
# Args:
#   $1 - Bloque de texto con entradas (hostname:puerto:usuario por línea).
#   $2 - Timeout SSH en segundos.
#   $3 - Modo verbose (1 = activado, 0 = desactivado).
#   $@ - Argumentos adicionales que se pasan al script remoto como $1, $2...
#
# Globals modificados:
#   G_SERVER, G_VMID, G_NAME, G_TYPE, G_STATUS, G_EXTRA  (resultados)
#   FAILED                                                (servidores fallidos)
declare -a FAILED=()
run_remote_collect() {
  local entries_blob="$1" timeout="$2" verbose="$3"; shift 3
  local extra_args=("$@")

  local -a SSH_OPTS=("${SSH_BASE_OPTS[@]}" -o ConnectTimeout="$timeout")

  local idx=0 total
  total="$(echo "$entries_blob" | grep -c . || true)"
  (( total == 0 )) && return 0

  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    idx=$(( idx + 1 ))

    IFS=':' read -r srv_h srv_p srv_u <<< "${entry}::"
    srv_p="${srv_p:-$DEFAULT_PORT}"; srv_u="${srv_u:-$DEFAULT_USER}"

    if (( verbose )); then
      printf "   ${DIM}[%d/%d]${RST} Conectando a ${BOLD}%s${RST}:%s  (usuario: %s)...\n" \
        "$idx" "$total" "$srv_h" "$srv_p" "$srv_u"
    else
      printf "   ${DIM}[%d/%d] %s${RST}\n" "$idx" "$total" "$srv_h"
    fi

    if ! ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" true 2>/dev/null; then
      warn "Sin respuesta: ${BOLD}${srv_h}${RST}:${srv_p}"
      FAILED+=("$srv_h")
      continue
    fi

    # Leer el script remoto desde stdin (heredoc del llamador) — no es posible
    # así que usamos un mecanismo de callback a través de variable global REMOTE_SCRIPT
    local raw=""
    raw="$(ssh "${SSH_OPTS[@]}" -p "$srv_p" "${srv_u}@${srv_h}" \
      bash -s -- "${extra_args[@]}" 2>/dev/null <<< "$REMOTE_SCRIPT")" || true

    if [[ -n "$raw" ]]; then
      while IFS='|' read -r vmid name status type extra; do
        [[ -z "$vmid" ]] && continue
        G_SERVER+=("$srv_h")
        G_VMID+=("$vmid")
        G_NAME+=("$name")
        G_STATUS+=("$status")
        G_TYPE+=("$type")
        G_EXTRA+=("${extra:-}")
      done <<< "$raw"
    fi
  done <<< "$entries_blob"
}

